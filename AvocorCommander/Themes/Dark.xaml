<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── Palette ──────────────────────────────────────────────────────────── -->

    <!-- Backgrounds -->
    <SolidColorBrush x:Key="AppBgBrush"         Color="#0F1117"/>
    <SolidColorBrush x:Key="SidebarBrush"        Color="#0D111C"/>
    <SolidColorBrush x:Key="SidebarHeaderBrush"  Color="#080C15"/>
    <SolidColorBrush x:Key="CardBrush"           Color="#171C2A"/>
    <SolidColorBrush x:Key="CardHoverBrush"      Color="#1D2336"/>
    <SolidColorBrush x:Key="PanelBrush"          Color="#131825"/>
    <SolidColorBrush x:Key="InputBgBrush"        Color="#1A2236"/>
    <SolidColorBrush x:Key="InfoBarBrush"        Color="#141928"/>
    <SolidColorBrush x:Key="LogBgBrush"          Color="#0C1018"/>
    <SolidColorBrush x:Key="TabActiveBrush"      Color="#1A2236"/>
    <SolidColorBrush x:Key="TabInactiveBrush"    Color="#0D111C"/>

    <!-- Borders -->
    <SolidColorBrush x:Key="BorderBrush"         Color="#1E2A3E"/>
    <SolidColorBrush x:Key="BorderAccentBrush"   Color="#0078D4"/>
    <SolidColorBrush x:Key="InputBorderBrush"    Color="#2E4868"/>
    <SolidColorBrush x:Key="DividerBrush"        Color="#182030"/>

    <!-- Text -->
    <SolidColorBrush x:Key="PrimaryTextBrush"    Color="#EDF2F8"/>
    <SolidColorBrush x:Key="SecondaryTextBrush"  Color="#A8B6C4"/>
    <SolidColorBrush x:Key="SubtleTextBrush"     Color="#6E8090"/>
    <SolidColorBrush x:Key="AccentTextBrush"     Color="#6AB4FF"/>
    <SolidColorBrush x:Key="LabelBrush"          Color="#C0CDD8"/>
    <SolidColorBrush x:Key="PlaceholderBrush"    Color="#4A607A"/>
    <SolidColorBrush x:Key="InputFgBrush"        Color="#DDE6F0"/>

    <!-- Accent / state -->
    <SolidColorBrush x:Key="AccentBrush"         Color="#0078D4"/>
    <SolidColorBrush x:Key="AccentHoverBrush"    Color="#1086E0"/>
    <SolidColorBrush x:Key="AccentPressedBrush"  Color="#006ABE"/>
    <SolidColorBrush x:Key="SuccessBrush"        Color="#16C080"/>
    <SolidColorBrush x:Key="ErrorBrush"          Color="#E74C3C"/>
    <SolidColorBrush x:Key="WarningBrush"        Color="#F39C12"/>
    <SolidColorBrush x:Key="WarnBgBrush"         Color="#2A1F06"/>
    <SolidColorBrush x:Key="WarnFgBrush"         Color="#D4AA40"/>

    <!-- Nav -->
    <SolidColorBrush x:Key="NavHoverBrush"        Color="#1A2236"/>
    <SolidColorBrush x:Key="NavActiveBrush"       Color="#1E2D48"/>
    <SolidColorBrush x:Key="NavActiveBorderBrush" Color="#0078D4"/>
    <SolidColorBrush x:Key="NavActiveBackBrush"   Color="#1E2D48"/>
    <SolidColorBrush x:Key="NavActiveForeBrush"   Color="#58A6FF"/>

</ResourceDictionary>
