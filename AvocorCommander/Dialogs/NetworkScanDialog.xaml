<Window x:Class="AvocorCommander.Dialogs.NetworkScanDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:core="clr-namespace:AvocorCommander.Core"
        Title="Scan Network for Avocor Devices"
        Width="720" Height="520"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppBgBrush}"
        Foreground="{DynamicResource PrimaryTextBrush}">

    <Window.Resources>
        <core:HexColorToBrushConverter x:Key="HexBrush"/>
        <core:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <core:BoolToVisibilityConverter x:Key="InvBoolToVis" Invert="True"/>
    </Window.Resources>

    <DockPanel>
        <!-- Header -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource PanelBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="20,14">
            <Grid>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="NETWORK SCANNER"
                               FontSize="10" FontWeight="Bold"
                               Foreground="{DynamicResource SubtleTextBrush}"/>
                    <TextBlock Text="Discover Avocor displays on your network"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               Margin="0,2,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Buttons bar -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource PanelBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="20,10">
            <Grid>
                <TextBlock x:Name="TxtStatus"
                           Text="Enter an IP range and click Scan."
                           FontSize="11"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           VerticalAlignment="Center"/>
                <StackPanel HorizontalAlignment="Right"
                            Orientation="Horizontal">
                    <Button x:Name="BtnCancel"
                            Content="Cancel Scan"
                            Style="{StaticResource SecondaryButton}"
                            Visibility="{Binding ElementName=BtnScan, Path=IsEnabled,
                                Converter={StaticResource InvBoolToVis}}"
                            Click="CancelScan_Click"
                            Margin="0,0,10,0"/>
                    <Button x:Name="BtnAddSelected"
                            Content="Add Selected Devices"
                            Style="{StaticResource PrimaryButton}"
                            IsEnabled="False"
                            Click="AddSelected_Click"
                            Margin="0,0,10,0"/>
                    <Button Content="Close"
                            Style="{StaticResource SecondaryButton}"
                            Click="Close_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Scan config -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource PanelBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Start IP"
                           Style="{StaticResource FieldLabel}"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox x:Name="TxtStartIp"
                         Grid.Column="1"
                         Text="192.168.1.1"
                         FontFamily="Consolas"
                         VerticalContentAlignment="Center"/>

                <TextBlock Grid.Column="3" Text="End IP"
                           Style="{StaticResource FieldLabel}"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox x:Name="TxtEndIp"
                         Grid.Column="4"
                         Text="192.168.1.254"
                         FontFamily="Consolas"
                         VerticalContentAlignment="Center"/>

                <Button x:Name="BtnScan"
                        Grid.Column="6"
                        Content="▶  Start Scan"
                        Style="{StaticResource PrimaryButton}"
                        Click="StartScan_Click"/>
            </Grid>
        </Border>

        <!-- Progress -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource InfoBarBrush}"
                Padding="20,8"
                x:Name="ProgressBar_Panel">
            <Grid>
                <ProgressBar x:Name="ScanProgress"
                             Height="4"
                             Minimum="0" Maximum="100" Value="0"
                             Background="{DynamicResource BorderBrush}"
                             Foreground="{DynamicResource AccentBrush}"/>
            </Grid>
        </Border>

        <!-- Select All bar -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource PanelBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="20,6">
            <CheckBox x:Name="ChkSelectAll"
                      Content="Select All"
                      IsThreeState="True"
                      Checked="SelectAll_Changed"
                      Unchecked="SelectAll_Changed"/>
        </Border>

        <!-- Results -->
        <DataGrid x:Name="ResultsGrid"
                  Margin="0"
                  FontSize="12"
                  SelectionMode="Extended"
                  SelectionChanged="Results_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="" Width="40">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Status" Width="70">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding StatusLabel}"
                                       FontSize="10" FontWeight="SemiBold"
                                       Foreground="{Binding StatusColor, Converter={StaticResource HexBrush}}"
                                       VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="IP Address"  Binding="{Binding IpAddress}"    Width="130"  FontFamily="Consolas"/>
                <DataGridTextColumn Header="MAC Address" Binding="{Binding MacAddress}"   Width="140"  FontFamily="Consolas"/>
                <DataGridTextColumn Header="Hostname"    Binding="{Binding Hostname}"     Width="130"/>
                <DataGridTextColumn Header="Series"      Binding="{Binding SeriesPattern}" Width="*"/>
                <DataGridTextColumn Header="Model"       Binding="{Binding ModelNumber}"  Width="120"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
