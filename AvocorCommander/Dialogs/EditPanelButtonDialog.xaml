<Window x:Class="AvocorCommander.Dialogs.EditPanelButtonDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:core="clr-namespace:AvocorCommander.Core"
        Title="Configure Button"
        Width="640" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource AppBgBrush}">

    <Window.Resources>
        <core:BoolToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="ColorSwatch" TargetType="RadioButton">
            <Setter Property="Width"  Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Root"
                                Width="28" Height="28"
                                CornerRadius="6"
                                Background="{TemplateBinding Tag}"
                                BorderThickness="2"
                                BorderBrush="Transparent"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconChoice" TargetType="RadioButton">
            <Setter Property="Width"  Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Root"
                                Width="36" Height="36"
                                CornerRadius="8"
                                Background="{DynamicResource InputBrush}"
                                BorderThickness="2"
                                BorderBrush="Transparent">
                            <TextBlock Text="{TemplateBinding Content}"
                                       FontSize="18"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource PrimaryTextBrush}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="Root" Property="Background"  Value="{DynamicResource NavActiveBackBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Shared action row template  (Device | Series | Command | Remove) -->
        <DataTemplate x:Key="ActionRowTemplate">
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ComboBox Grid.Column="0"
                          ItemsSource="{Binding Devices}"
                          SelectedItem="{Binding SelectedDevice, Mode=TwoWay}"
                          DisplayMemberPath="DeviceName"/>
                <ComboBox Grid.Column="2"
                          ItemsSource="{Binding AllSeries}"
                          SelectedItem="{Binding SelectedSeries, Mode=TwoWay}"/>
                <ComboBox Grid.Column="4"
                          ItemsSource="{Binding Commands}"
                          SelectedItem="{Binding SelectedCommand, Mode=TwoWay}"
                          DisplayMemberPath="CommandName"/>
                <!-- Remove button wired in code-behind via Tag + Click -->
                <Button Grid.Column="6" Content="✕"
                        Style="{StaticResource IconButton}"
                        Tag="{Binding}"
                        x:Name="BtnRemove"/>
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <StackPanel Margin="24">

        <!-- Label + toggle -->
        <TextBlock Text="BUTTON LABEL" FontSize="9" FontWeight="Bold"
                   Foreground="{DynamicResource SubtleTextBrush}" Margin="0,0,0,6"/>
        <Grid Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="TxtLabel" Grid.Column="0"/>
            <CheckBox x:Name="ChkToggle" Grid.Column="2"
                      Content="Toggle button"
                      Foreground="{DynamicResource PrimaryTextBrush}"
                      VerticalAlignment="Center"/>
        </Grid>

        <!-- Icon picker -->
        <TextBlock Text="ICON" FontSize="9" FontWeight="Bold"
                   Foreground="{DynamicResource SubtleTextBrush}" Margin="0,0,0,6"/>
        <Border Background="{DynamicResource PanelBrush}"
                CornerRadius="8" Padding="8" Margin="0,0,0,16">
            <WrapPanel x:Name="IconPanel" Orientation="Horizontal"/>
        </Border>

        <!-- Colour picker -->
        <TextBlock Text="COLOUR" FontSize="9" FontWeight="Bold"
                   Foreground="{DynamicResource SubtleTextBrush}" Margin="0,0,0,6"/>
        <Border Background="{DynamicResource PanelBrush}"
                CornerRadius="8" Padding="8" Margin="0,0,0,16">
            <WrapPanel x:Name="ColorPanel" Orientation="Horizontal"/>
        </Border>

        <!-- Phase A actions -->
        <TextBlock Text="ACTIONS — PHASE A  (or toggle OFF → ON)"
                   FontSize="9" FontWeight="Bold"
                   Foreground="{DynamicResource SubtleTextBrush}" Margin="0,0,0,6"/>
        <Border Background="{DynamicResource PanelBrush}" CornerRadius="8" Padding="12" Margin="0,0,0,4">
            <StackPanel>
                <!-- Column headers -->
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="32"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Device"   FontSize="10" Foreground="{DynamicResource SubtleTextBrush}"/>
                    <TextBlock Grid.Column="2" Text="Series"   FontSize="10" Foreground="{DynamicResource SubtleTextBrush}"/>
                    <TextBlock Grid.Column="4" Text="Command"  FontSize="10" Foreground="{DynamicResource SubtleTextBrush}"/>
                </Grid>
                <ItemsControl x:Name="ActionsAList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox Grid.Column="0"
                                          ItemsSource="{Binding Devices}"
                                          SelectedItem="{Binding SelectedDevice, Mode=TwoWay}"
                                          DisplayMemberPath="DeviceName"/>
                                <ComboBox Grid.Column="2"
                                          ItemsSource="{Binding AllSeries}"
                                          SelectedItem="{Binding SelectedSeries, Mode=TwoWay}"/>
                                <ComboBox Grid.Column="4"
                                          ItemsSource="{Binding Commands}"
                                          SelectedItem="{Binding SelectedCommand, Mode=TwoWay}"
                                          DisplayMemberPath="CommandName"/>
                                <Button Grid.Column="6" Content="✕"
                                        Style="{StaticResource IconButton}"
                                        Tag="{Binding}"
                                        Click="RemoveActionA_Click"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <Button Content="＋  Add Action"
                        Style="{StaticResource SecondaryButton}"
                        Padding="10,5" FontSize="11" HorizontalAlignment="Left"
                        Margin="0,4,0,0"
                        Click="AddActionA_Click"/>
            </StackPanel>
        </Border>

        <!-- Phase B actions (toggle only) -->
        <StackPanel Visibility="{Binding IsChecked, ElementName=ChkToggle, Converter={StaticResource BoolToVis}}"
                    Margin="0,12,0,0">
            <TextBlock Text="ACTIONS — PHASE B  (toggle ON → OFF)"
                       FontSize="9" FontWeight="Bold"
                       Foreground="{DynamicResource SubtleTextBrush}" Margin="0,0,0,6"/>
            <Border Background="{DynamicResource PanelBrush}" CornerRadius="8" Padding="12" Margin="0,0,0,4">
                <StackPanel>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="32"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Device"  FontSize="10" Foreground="{DynamicResource SubtleTextBrush}"/>
                        <TextBlock Grid.Column="2" Text="Series"  FontSize="10" Foreground="{DynamicResource SubtleTextBrush}"/>
                        <TextBlock Grid.Column="4" Text="Command" FontSize="10" Foreground="{DynamicResource SubtleTextBrush}"/>
                    </Grid>
                    <ItemsControl x:Name="ActionsBList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox Grid.Column="0"
                                              ItemsSource="{Binding Devices}"
                                              SelectedItem="{Binding SelectedDevice, Mode=TwoWay}"
                                              DisplayMemberPath="DeviceName"/>
                                    <ComboBox Grid.Column="2"
                                              ItemsSource="{Binding AllSeries}"
                                              SelectedItem="{Binding SelectedSeries, Mode=TwoWay}"/>
                                    <ComboBox Grid.Column="4"
                                              ItemsSource="{Binding Commands}"
                                              SelectedItem="{Binding SelectedCommand, Mode=TwoWay}"
                                              DisplayMemberPath="CommandName"/>
                                    <Button Grid.Column="6" Content="✕"
                                            Style="{StaticResource IconButton}"
                                            Tag="{Binding}"
                                            Click="RemoveActionB_Click"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Button Content="＋  Add Action"
                            Style="{StaticResource SecondaryButton}"
                            Padding="10,5" FontSize="11" HorizontalAlignment="Left"
                            Margin="0,4,0,0"
                            Click="AddActionB_Click"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Dialog buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Cancel"
                    Style="{StaticResource SecondaryButton}"
                    Padding="16,8" Margin="0,0,8,0"
                    Click="Cancel_Click"/>
            <Button Content="Save"
                    Style="{StaticResource PrimaryButton}"
                    Padding="20,8"
                    Click="Save_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
