<Window x:Class="AvocorCommander.Dialogs.AddDeviceDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add / Edit Device"
        Width="460" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource AppBgBrush}"
        Foreground="{DynamicResource PrimaryTextBrush}">

    <Border Padding="24">
        <StackPanel>
            <TextBlock Text="DEVICE DETAILS"
                       FontSize="10" FontWeight="Bold"
                       Foreground="{DynamicResource SubtleTextBrush}"
                       Margin="0,0,0,16"/>

            <!-- Name -->
            <TextBlock Text="Device Name" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="TxtName" Margin="0,0,0,12"/>

            <!-- Model -->
            <TextBlock Text="Model Number" Style="{StaticResource FieldLabel}"/>
            <ComboBox x:Name="CmbModel"
                      IsEditable="True"
                      Margin="0,0,0,12"
                      SelectionChanged="CmbModel_SelectionChanged"/>

            <!-- Connection type -->
            <TextBlock Text="Connection Type" Style="{StaticResource FieldLabel}"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                <RadioButton x:Name="RdoTcp"    Content="TCP / IP"  IsChecked="True"
                             Checked="ConnType_Changed"/>
                <RadioButton x:Name="RdoSerial" Content="RS-232 Serial"
                             Checked="ConnType_Changed"/>
            </StackPanel>

            <!-- TCP panel -->
            <StackPanel x:Name="TcpPanel">
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="90"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="IP Address" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="TxtIp"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Port" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="TxtPort"/>
                    </StackPanel>
                </Grid>
                <TextBlock Text="MAC Address (optional — for Wake on LAN)"
                           Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="TxtMac" FontFamily="Consolas" Margin="0,0,0,12"/>
            </StackPanel>

            <!-- Serial panel -->
            <StackPanel x:Name="SerialPanel" Visibility="Collapsed">
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="COM Port" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="CmbComPort"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Baud Rate" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="CmbBaud">
                            <ComboBoxItem Content="9600"/>
                            <ComboBoxItem Content="19200"/>
                            <ComboBoxItem Content="38400"/>
                            <ComboBoxItem Content="57600"/>
                            <ComboBoxItem Content="115200"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>
            </StackPanel>

            <!-- Notes -->
            <TextBlock Text="Notes (optional)" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="TxtNotes" Margin="0,0,0,20"/>

            <!-- Buttons -->
            <Separator Margin="0,0,0,14"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel"
                        Style="{StaticResource SecondaryButton}"
                        Margin="0,0,10,0"
                        IsCancel="True"
                        Click="Cancel_Click"/>
                <Button Content="Save Device"
                        Style="{StaticResource PrimaryButton}"
                        IsDefault="True"
                        Click="Save_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
