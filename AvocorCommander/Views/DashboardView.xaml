<UserControl x:Class="AvocorCommander.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:core="clr-namespace:AvocorCommander.Core">

    <UserControl.Resources>
        <core:HexColorToBrushConverter  x:Key="HexBrush"/>
        <core:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <core:BoolToVisibilityConverter x:Key="InvBoolToVis" Invert="True"/>
    </UserControl.Resources>

    <DockPanel>

        <!-- Header -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource PanelBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1" Padding="20,14">
            <Grid>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="DASHBOARD"
                               FontSize="10" FontWeight="Bold"
                               Foreground="{DynamicResource SubtleTextBrush}"/>
                    <TextBlock Text="Live device overview"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,2,0,0"/>
                </StackPanel>
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding SummaryText}"
                               FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"
                               VerticalAlignment="Center" Margin="0,0,16,0"/>
                    <TextBlock Text="Refreshing…"
                               FontSize="11" Foreground="{DynamicResource AccentTextBrush}"
                               VerticalAlignment="Center" Margin="0,0,12,0"
                               Visibility="{Binding IsRefreshing, Converter={StaticResource BoolToVis}}"/>
                    <Button Content="&#8635;  Refresh All"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding RefreshCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Tile grid -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <TextBlock Text="No devices found. Add devices in the Devices section."
                           Foreground="{DynamicResource PlaceholderBrush}"
                           FontSize="13" TextAlignment="Center" HorizontalAlignment="Center"
                           Margin="0,80,0,0"
                           Visibility="{Binding Tiles.Count, Converter={StaticResource InvBoolToVis}}"/>

                <ItemsControl ItemsSource="{Binding Tiles}" Margin="16,14,16,14">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="230" Margin="0,0,12,12"
                                    Style="{StaticResource Card}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="4"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Online/Offline colour bar -->
                                    <Border Grid.Column="0" CornerRadius="2"
                                            Background="{Binding StatusColor, Converter={StaticResource HexBrush}}"/>

                                    <!-- Tile content -->
                                    <StackPanel Grid.Column="1" Margin="10,0,0,0">

                                        <!-- Name + model -->
                                        <TextBlock Text="{Binding Device.DeviceName}"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Device.ModelNumber}"
                                                   FontSize="11" Margin="0,1,0,0"
                                                   Foreground="{DynamicResource SubtleTextBrush}"/>

                                        <!-- Address -->
                                        <TextBlock Text="{Binding Device.AddressSummary}"
                                                   FontSize="11" Margin="0,5,0,0"
                                                   FontFamily="Consolas"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                   TextTrimming="CharacterEllipsis"/>

                                        <!-- Connection type badge -->
                                        <TextBlock FontSize="10" Margin="0,2,0,0"
                                                   Foreground="{DynamicResource SubtleTextBrush}">
                                            <Run Text="{Binding Device.ConnectionType, Mode=OneWay}"/>
                                        </TextBlock>

                                        <!-- Notes -->
                                        <TextBlock Text="{Binding Device.Notes}"
                                                   FontSize="10" Margin="0,2,0,0"
                                                   Foreground="{DynamicResource PlaceholderBrush}"
                                                   TextTrimming="CharacterEllipsis"
                                                   Visibility="{Binding Device.Notes, Converter={StaticResource BoolToVis}}"/>

                                        <!-- Divider -->
                                        <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,6,0,6"/>

                                        <!-- Online status + latency -->
                                        <Grid>
                                            <StackPanel Orientation="Horizontal">
                                                <Ellipse Width="7" Height="7" Margin="0,0,5,0" VerticalAlignment="Center"
                                                         Fill="{Binding StatusColor, Converter={StaticResource HexBrush}}"/>
                                                <TextBlock Text="{Binding StatusLabel}"
                                                           FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{Binding StatusColor, Converter={StaticResource HexBrush}}"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBlock HorizontalAlignment="Right"
                                                       Text="{Binding Latency}"
                                                       FontSize="11" FontFamily="Consolas"
                                                       Foreground="{DynamicResource SubtleTextBrush}"/>
                                        </Grid>

                                        <!-- Last seen -->
                                        <TextBlock FontSize="10" Margin="0,2,0,0"
                                                   Foreground="{DynamicResource SubtleTextBrush}">
                                            <Run Text="Ping: "/>
                                            <Run Text="{Binding LastSeen, Mode=OneWay, FallbackValue='—'}"/>
                                        </TextBlock>

                                        <!-- Active connection badge -->
                                        <Border Margin="0,5,0,0" Padding="6,2"
                                                CornerRadius="3" HorizontalAlignment="Left"
                                                Background="#1A2D1A"
                                                Visibility="{Binding Device.IsConnected, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="● CONNECTED"
                                                       FontSize="9" FontWeight="Bold"
                                                       Foreground="#16C080"/>
                                        </Border>

                                        <!-- Wake on LAN -->
                                        <Button Content="⚡ Wake"
                                                FontSize="9"
                                                Style="{StaticResource SecondaryButton}"
                                                Padding="6,2" Margin="0,3,0,0"
                                                HorizontalAlignment="Left"
                                                Command="{Binding DataContext.WakeOnLanCommand,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Visibility="{Binding Device.MacAddress, Converter={StaticResource BoolToVis}}"/>

                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>

    </DockPanel>
</UserControl>
