<UserControl x:Class="AvocorCommander.Views.GroupsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:core="clr-namespace:AvocorCommander.Core">

    <UserControl.Resources>
        <core:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <core:BoolToVisibilityConverter x:Key="InvBoolToVis" Invert="True"/>
    </UserControl.Resources>

    <DockPanel>

        <!-- Header -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource PanelBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1" Padding="20,14">
            <Grid>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="GROUPS"
                               FontSize="10" FontWeight="Bold"
                               Foreground="{DynamicResource SubtleTextBrush}"/>
                    <TextBlock Text="Manage device groups"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,2,0,0"/>
                </StackPanel>
                <Button HorizontalAlignment="Right"
                        Content="&#65291;  New Group"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding AddGroupCommand}"/>
            </Grid>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource PanelBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0" Padding="20,6">
            <TextBlock Text="{Binding StatusMessage}" FontSize="11"
                       Foreground="{DynamicResource SecondaryTextBrush}"/>
        </Border>

        <!-- Body: group list | edit panel -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" MinWidth="180"/>
                <ColumnDefinition Width="1"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── Group list ──────────────────────────────────────────────── -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Padding="14,12">
                <StackPanel>

                    <TextBlock Text="No groups yet. Click ＋ New Group to create one."
                               Foreground="{DynamicResource PlaceholderBrush}"
                               FontSize="13" TextAlignment="Center" TextWrapping="Wrap"
                               MaxWidth="220" HorizontalAlignment="Center" Margin="0,50,0,0"
                               Visibility="{Binding Groups.Count, Converter={StaticResource InvBoolToVis}}"/>

                    <ItemsControl ItemsSource="{Binding Groups}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,8" Style="{StaticResource Card}"
                                        Cursor="Hand" MouseLeftButtonUp="GroupCard_Click">
                                    <Grid>
                                        <StackPanel Margin="0,0,32,0">
                                            <TextBlock Text="{Binding GroupName}"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"/>
                                            <TextBlock Text="{Binding MemberSummary}"
                                                       FontSize="11" Foreground="{DynamicResource SubtleTextBrush}"
                                                       Margin="0,2,0,0"/>
                                            <TextBlock Text="{Binding Notes}"
                                                       FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"
                                                       TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <Button Content="&#10005;"
                                                Style="{StaticResource IconButton}"
                                                ToolTip="Delete group"
                                                HorizontalAlignment="Right" VerticalAlignment="Center"
                                                Foreground="{DynamicResource ErrorBrush}"
                                                Command="{Binding DataContext.DeleteGroupCommand,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>
            </ScrollViewer>

            <!-- Divider -->
            <Border Grid.Column="1" Background="{DynamicResource BorderBrush}"/>

            <!-- ── Edit panel ──────────────────────────────────────────────── -->
            <DockPanel Grid.Column="2">

                <!-- Placeholder when nothing is selected -->
                <TextBlock DockPanel.Dock="Top"
                           Text="Click a group on the left to manage it."
                           Foreground="{DynamicResource PlaceholderBrush}" FontSize="13"
                           TextAlignment="Center" HorizontalAlignment="Center" Margin="0,80,0,0"
                           Visibility="{Binding HasSelection, Converter={StaticResource InvBoolToVis}}"/>

                <!-- Edit panel (visible when group selected) -->
                <StackPanel DockPanel.Dock="Top"
                            Margin="24,20,24,0"
                            Visibility="{Binding HasSelection, Converter={StaticResource BoolToVis}}">

                    <!-- Name field -->
                    <TextBlock Text="GROUP NAME"
                               FontSize="9" FontWeight="Bold"
                               Foreground="{DynamicResource SubtleTextBrush}" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="14" FontWeight="SemiBold" Padding="8,6" Margin="0,0,0,12"/>

                    <!-- Notes field -->
                    <TextBlock Text="NOTES"
                               FontSize="9" FontWeight="Bold"
                               Foreground="{DynamicResource SubtleTextBrush}" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding EditNotes, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="12" Padding="8,6" Margin="0,0,0,12"
                             AcceptsReturn="True" MinHeight="50" TextWrapping="Wrap"/>

                    <Button Content="&#10003;  Save Changes"
                            Style="{StaticResource PrimaryButton}"
                            HorizontalAlignment="Left"
                            Command="{Binding SaveGroupCommand}"
                            Margin="0,0,0,12"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Button Content="⚡ Connect All"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding ConnectGroupCommand}"
                                CommandParameter="{Binding SelectedGroup}"
                                Margin="0,0,8,0"/>
                        <Button Content="✕ Disconnect All"
                                Style="{StaticResource DangerButton}"
                                Command="{Binding DisconnectGroupCommand}"
                                CommandParameter="{Binding SelectedGroup}"/>
                    </StackPanel>

                    <!-- Members section -->
                    <TextBlock Text="MEMBER DEVICES"
                               FontSize="9" FontWeight="Bold"
                               Foreground="{DynamicResource SubtleTextBrush}" Margin="0,0,0,8"/>

                    <!-- Add device row -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox Grid.Column="0"
                                  ItemsSource="{Binding NonMemberDevices}"
                                  SelectedItem="{Binding DeviceToAdd}"
                                  DisplayMemberPath="DeviceName"
                                  Height="30"/>
                        <Button Grid.Column="2"
                                Content="&#65291;  Add"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding AddMemberCommand}"/>
                    </Grid>

                    <!-- No members hint -->
                    <TextBlock Text="No devices in this group yet."
                               Foreground="{DynamicResource PlaceholderBrush}" FontSize="12"
                               Margin="0,4,0,0"
                               Visibility="{Binding MemberDevices.Count, Converter={StaticResource InvBoolToVis}}"/>

                    <!-- Member list -->
                    <ItemsControl ItemsSource="{Binding MemberDevices}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource Card}"
                                        Margin="0,0,0,6">
                                    <Grid>
                                        <StackPanel Margin="0,0,36,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding DeviceName}"
                                                       FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"/>
                                            <TextBlock FontSize="11"
                                                       Foreground="{DynamicResource SubtleTextBrush}"
                                                       Margin="0,2,0,0">
                                                <Run Text="{Binding ModelNumber, Mode=OneWay}"/>
                                                <Run Text="  ·  "/>
                                                <Run Text="{Binding AddressSummary, Mode=OneWay}"/>
                                            </TextBlock>
                                        </StackPanel>
                                        <Button Content="&#10005;"
                                                Style="{StaticResource IconButton}"
                                                ToolTip="Remove from group"
                                                HorizontalAlignment="Right" VerticalAlignment="Center"
                                                Foreground="{DynamicResource ErrorBrush}"
                                                Command="{Binding DataContext.RemoveMemberCommand,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>

            </DockPanel>

        </Grid>
    </DockPanel>
</UserControl>
