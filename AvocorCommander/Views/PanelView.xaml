<UserControl x:Class="AvocorCommander.Views.PanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:core="clr-namespace:AvocorCommander.Core"
             xmlns:vm="clr-namespace:AvocorCommander.ViewModels">

    <UserControl.Resources>
        <core:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <core:BoolToVisibilityConverter x:Key="InvBoolToVis" Invert="True"/>
        <core:CountToVisibilityConverter x:Key="InvCountToVis" Invert="True"/>

        <!-- ── Panel button card style ──────────────────────────────────────── -->
        <Style x:Key="PanelButtonCard" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                CornerRadius="14"
                                Background="{TemplateBinding Tag}"
                                Cursor="Hand"
                                Opacity="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="8"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.82"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.65"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Page tab item style ─────────────────────────────────────────── -->
        <Style x:Key="PageTabItem" TargetType="ListBoxItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Root"
                                Background="Transparent"
                                CornerRadius="16"
                                Padding="14,6"
                                Margin="0,0,6,0"
                                Cursor="Hand">
                            <TextBlock x:Name="Txt"
                                       Text="{Binding Name}"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource SecondaryTextBrush}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="Txt"  Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource NavActiveBackBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <DockPanel>

        <!-- ── Header ──────────────────────────────────────────────────────── -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource PanelBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" MinWidth="180"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: scene selector -->
                <StackPanel Grid.Column="0" Orientation="Vertical" VerticalAlignment="Center">
                    <TextBlock Text="PANEL" FontSize="9" FontWeight="Bold"
                               Foreground="{DynamicResource SubtleTextBrush}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <ComboBox ItemsSource="{Binding Scenes}"
                                  SelectedItem="{Binding SelectedScene, Mode=TwoWay}"
                                  DisplayMemberPath="Name"
                                  Width="160"
                                  Visibility="{Binding HasScenes, Converter={StaticResource BoolToVis}}"/>
                        <Button Content="＋ Scene"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding AddSceneCommand}"
                                Margin="8,0,0,0" Padding="10,4" FontSize="11"/>
                        <Button Content="✏"
                                Style="{StaticResource IconButton}"
                                Command="{Binding RenameSceneCommand}"
                                ToolTip="Rename scene"
                                Visibility="{Binding HasScenes, Converter={StaticResource BoolToVis}}"/>
                        <Button Content="✕"
                                Style="{StaticResource IconButton}"
                                Command="{Binding DeleteSceneCommand}"
                                ToolTip="Delete scene"
                                Visibility="{Binding HasScenes, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Centre: live clock -->
                <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="{Binding TimeText}"
                               FontSize="28" FontWeight="Light"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding DateText}"
                               FontSize="11"
                               Foreground="{DynamicResource SubtleTextBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Right: edit + kiosk -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Command="{Binding ToggleEditModeCommand}"
                            Padding="12,6" FontSize="11"
                            Margin="0,0,8,0"
                            Visibility="{Binding HasScenes, Converter={StaticResource BoolToVis}}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                <Setter Property="Content" Value="✏  Edit"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                        <Setter Property="Content"     Value="✔  Done"/>
                                        <Setter Property="Background"  Value="{DynamicResource AccentBrush}"/>
                                        <Setter Property="Foreground"  Value="White"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="🔒"
                            Style="{StaticResource IconButton}"
                            Command="{Binding ToggleKioskModeCommand}"
                            ToolTip="Toggle kiosk mode"
                            FontSize="16"
                            Visibility="{Binding HasScenes, Converter={StaticResource BoolToVis}}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Bottom bar ───────────────────────────────────────────────────── -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource PanelBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0"
                MinHeight="78"
                Padding="16,10">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled">
                <StackPanel Orientation="Horizontal">
                    <ItemsControl ItemsSource="{Binding BottomButtons}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:PanelButtonVM}">
                                <Grid Margin="0,0,8,0">
                                    <Button Width="80" Height="56"
                                            Tag="{Binding Color}"
                                            Style="{StaticResource PanelButtonCard}"
                                            Command="{Binding DataContext.ExecuteBottomButtonCommand,
                                                RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding Icon}" FontSize="20"
                                                       HorizontalAlignment="Center"
                                                       Foreground="White"/>
                                            <TextBlock Text="{Binding Label}" FontSize="10"
                                                       HorizontalAlignment="Center"
                                                       Foreground="White"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxWidth="74"/>
                                        </StackPanel>
                                    </Button>
                                    <!-- Edit overlay -->
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Right" VerticalAlignment="Top"
                                                Margin="0,-6,-6,0"
                                                Visibility="{Binding DataContext.IsEditMode,
                                                    RelativeSource={RelativeSource AncestorType=UserControl},
                                                    Converter={StaticResource BoolToVis}}">
                                        <Button Content="✏" Style="{StaticResource IconButton}"
                                                FontSize="9" Width="18" Height="18"
                                                Command="{Binding DataContext.EditBottomButtonCommand,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                        <Button Content="✕" Style="{StaticResource IconButton}"
                                                FontSize="9" Width="18" Height="18"
                                                Command="{Binding DataContext.RemoveBottomButtonCommand,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Add bottom button (edit mode only) -->
                    <Button Width="56" Height="56"
                            Content="＋"
                            Style="{StaticResource SecondaryButton}"
                            FontSize="22"
                            Command="{Binding AddBottomButtonCommand}"
                            ToolTip="Add bottom bar button"
                            Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVis}}"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- ── Page tab bar ─────────────────────────────────────────────────── -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource PanelBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,8"
                Visibility="{Binding HasScenes, Converter={StaticResource BoolToVis}}">
            <StackPanel Orientation="Horizontal">
                <ListBox ItemsSource="{Binding Pages}"
                         SelectedItem="{Binding SelectedPage, Mode=TwoWay}"
                         ItemContainerStyle="{StaticResource PageTabItem}"
                         Background="Transparent"
                         BorderThickness="0">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                </ListBox>
                <!-- Add page / rename page (edit mode) -->
                <Button Content="＋ Page"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding AddPageCommand}"
                        Padding="10,5" FontSize="11" Margin="8,0,0,0"
                        Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVis}}"/>
                <Button Content="✏"
                        Style="{StaticResource IconButton}"
                        Command="{Binding RenamePageCommand}"
                        ToolTip="Rename page"
                        Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVis}}"/>
                <Button Content="✕"
                        Style="{StaticResource IconButton}"
                        Command="{Binding DeletePageCommand}"
                        ToolTip="Delete page"
                        Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVis}}"/>
            </StackPanel>
        </Border>

        <!-- ── Button grid ──────────────────────────────────────────────────── -->
        <Grid>
            <!-- Empty state — no scenes yet -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                        Visibility="{Binding HasScenes, Converter={StaticResource InvBoolToVis}}">
                <TextBlock Text="No scenes yet."
                           FontSize="18" FontWeight="SemiBold"
                           Foreground="{DynamicResource SubtleTextBrush}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Click ＋ Scene to create your first touch panel layout."
                           FontSize="13"
                           Foreground="{DynamicResource PlaceholderBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,0"/>
                <Button Content="＋  Create Scene"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding AddSceneCommand}"
                        HorizontalAlignment="Center"
                        Padding="24,10" FontSize="13"
                        Margin="0,20,0,0"/>
            </StackPanel>

            <!-- Grid of buttons -->
            <UniformGrid Columns="4" Rows="3"
                         Margin="16"
                         Visibility="{Binding HasScenes, Converter={StaticResource BoolToVis}}">
                <UniformGrid.Resources>
                    <DataTemplate DataType="{x:Type vm:PanelGridSlot}">
                        <Grid Margin="6">
                            <!-- Occupied: button card -->
                            <Button Tag="{Binding Button.Color}"
                                    Style="{StaticResource PanelButtonCard}"
                                    Command="{Binding DataContext.ExecuteGridSlotCommand,
                                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    Visibility="{Binding IsEmpty, Converter={StaticResource InvBoolToVis}}">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding Button.Icon}"
                                               FontSize="32"
                                               HorizontalAlignment="Center"
                                               Foreground="White"/>
                                    <TextBlock Text="{Binding Button.Label}"
                                               FontSize="12"
                                               HorizontalAlignment="Center"
                                               Foreground="White"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="4,4,4,0"/>
                                </StackPanel>
                            </Button>

                            <!-- Edit overlay on occupied slot -->
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Right" VerticalAlignment="Top"
                                        Margin="0,2,2,0"
                                        Panel.ZIndex="5"
                                        Visibility="{Binding ShowEditOverlay, Converter={StaticResource BoolToVis}}">
                                <Button Content="✏" Style="{StaticResource IconButton}"
                                        FontSize="10" Width="22" Height="22"
                                        Command="{Binding DataContext.EditGridSlotCommand,
                                            RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"/>
                                <Button Content="✕" Style="{StaticResource IconButton}"
                                        FontSize="10" Width="22" Height="22"
                                        Command="{Binding DataContext.RemoveGridButtonCommand,
                                            RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"/>
                            </StackPanel>

                            <!-- Empty placeholder (edit mode) -->
                            <Border CornerRadius="14"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="2"
                                    Background="Transparent"
                                    Cursor="Hand"
                                    Visibility="{Binding ShowAddPlaceholder, Converter={StaticResource BoolToVis}}">
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick"
                                                  Command="{Binding DataContext.EditGridSlotCommand,
                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  CommandParameter="{Binding}"/>
                                </Border.InputBindings>
                                <TextBlock Text="＋"
                                           FontSize="28"
                                           Foreground="{DynamicResource SubtleTextBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </UniformGrid.Resources>

                <ContentControl Content="{Binding GridSlots[0]}"  Focusable="False"/>
                <ContentControl Content="{Binding GridSlots[1]}"  Focusable="False"/>
                <ContentControl Content="{Binding GridSlots[2]}"  Focusable="False"/>
                <ContentControl Content="{Binding GridSlots[3]}"  Focusable="False"/>
                <ContentControl Content="{Binding GridSlots[4]}"  Focusable="False"/>
                <ContentControl Content="{Binding GridSlots[5]}"  Focusable="False"/>
                <ContentControl Content="{Binding GridSlots[6]}"  Focusable="False"/>
                <ContentControl Content="{Binding GridSlots[7]}"  Focusable="False"/>
                <ContentControl Content="{Binding GridSlots[8]}"  Focusable="False"/>
                <ContentControl Content="{Binding GridSlots[9]}"  Focusable="False"/>
                <ContentControl Content="{Binding GridSlots[10]}" Focusable="False"/>
                <ContentControl Content="{Binding GridSlots[11]}" Focusable="False"/>
            </UniformGrid>
        </Grid>
    </DockPanel>
</UserControl>
