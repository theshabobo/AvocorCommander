<UserControl x:Class="AvocorCommander.Views.DevicesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:core="clr-namespace:AvocorCommander.Core">

    <UserControl.Resources>
        <core:BoolToColorBrushConverter x:Key="StatusBrush">
            <core:BoolToColorBrushConverter.TrueColor>
                <SolidColorBrush Color="#16C080"/>
            </core:BoolToColorBrushConverter.TrueColor>
            <core:BoolToColorBrushConverter.FalseColor>
                <SolidColorBrush Color="#E74C3C"/>
            </core:BoolToColorBrushConverter.FalseColor>
        </core:BoolToColorBrushConverter>
        <core:BoolToVisibilityConverter   x:Key="BoolToVis"/>
        <core:BoolToVisibilityConverter   x:Key="InvBoolToVis"   Invert="True"/>
        <core:CountToVisibilityConverter  x:Key="InvCountToVis"  Invert="True"/>
    </UserControl.Resources>

    <DockPanel>
        <!-- ── Section header ─────────────────────────────────────────────── -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource PanelBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="20,14">
            <Grid>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="DEVICES"
                               FontSize="10" FontWeight="Bold"
                               Foreground="{DynamicResource SubtleTextBrush}"/>
                    <TextBlock Text="Manage display connections"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               Margin="0,2,0,0"/>
                </StackPanel>
                <StackPanel HorizontalAlignment="Right"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Content="↓  Import"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding ImportDevicesCommand}"
                            ToolTip="Import devices from a JSON file"
                            Margin="0,0,8,0"/>
                    <Button Content="↑  Export"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding ExportDevicesCommand}"
                            ToolTip="Export all devices to a JSON file"
                            Margin="0,0,8,0"/>
                    <Button Content="⌕  Scan Network"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding ScanNetworkCommand}"
                            Margin="0,0,8,0"/>
                    <Button Content="＋  Add Device"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding AddDeviceCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Status bar ─────────────────────────────────────────────────── -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource PanelBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="20,6">
            <TextBlock Text="{Binding StatusMessage}"
                       FontSize="11"
                       Foreground="{DynamicResource SecondaryTextBrush}"/>
        </Border>

        <!-- ── Device list ────────────────────────────────────────────────── -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="16,12">
            <StackPanel>

            <!-- Empty state -->
            <TextBlock Text="No devices yet. Click ＋ Add Device or ⌕ Scan Network to get started."
                       Foreground="{DynamicResource PlaceholderBrush}"
                       FontSize="13" TextAlignment="Center"
                       HorizontalAlignment="Center"
                       Margin="0,60,0,0"
                       TextWrapping="Wrap" MaxWidth="340"
                       Visibility="{Binding Devices.Count,
                           Converter={StaticResource InvCountToVis}}"/>

            <ItemsControl ItemsSource="{Binding Devices}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!-- Device card -->
                        <Border Width="260" Margin="0,0,12,12"
                                Style="{StaticResource Card}"
                                Cursor="Hand">
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftClick"
                                              Command="{Binding DataContext.EditDeviceCommand,
                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                              CommandParameter="{Binding}"/>
                            </Border.InputBindings>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="10"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Row 0: Name + action buttons -->
                                <Grid Grid.Row="0">
                                    <TextBlock Text="{Binding DeviceName}"
                                               FontSize="14" FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Right">
                                        <Button Content="▶" Style="{StaticResource IconButton}"
                                                ToolTip="Open in Control"
                                                Command="{Binding DataContext.ControlDeviceCommand,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                        <Button Content="⚡" Style="{StaticResource IconButton}"
                                                ToolTip="Wake on LAN"
                                                Command="{Binding DataContext.WakeOnLanCommand,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                        <Button Content="☰" Style="{StaticResource IconButton}"
                                                ToolTip="View command history"
                                                Command="{Binding DataContext.ViewHistoryCommand,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                        <Button Content="✏" Style="{StaticResource IconButton}"
                                                ToolTip="Edit"
                                                Command="{Binding DataContext.EditDeviceCommand,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                        <Button Content="✕" Style="{StaticResource IconButton}"
                                                ToolTip="Remove"
                                                Command="{Binding DataContext.DeleteDeviceCommand,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Row 2: Details -->
                                <StackPanel Grid.Row="2" Orientation="Vertical">
                                    <TextBlock Text="{Binding ModelNumber}"
                                               FontSize="11"
                                               Foreground="{DynamicResource AccentTextBrush}"/>
                                    <TextBlock Text="{Binding AddressSummary}"
                                               FontSize="11"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               Margin="0,2,0,0"/>
                                    <TextBlock Text="{Binding ConnectionType}"
                                               FontSize="10"
                                               Foreground="{DynamicResource SubtleTextBrush}"
                                               Margin="0,2,0,0"/>
                                    <TextBlock Text="{Binding Notes}"
                                               FontSize="10"
                                               Foreground="{DynamicResource SubtleTextBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,3,0,0"
                                               Visibility="{Binding Notes, Converter={StaticResource BoolToVis}}"/>
                                    <TextBlock Text="{Binding LastSeenDisplay}"
                                               FontSize="10"
                                               Foreground="{DynamicResource SubtleTextBrush}"
                                               Margin="0,2,0,0"/>
                                </StackPanel>

                                <!-- Row 4: Status + connect/disconnect -->
                                <Grid Grid.Row="4">
                                    <StackPanel Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <Ellipse Width="7" Height="7"
                                                 Fill="{Binding IsConnected,
                                                     Converter={StaticResource StatusBrush}}"
                                                 Margin="0,0,6,0"
                                                 VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding StatusText}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <Button HorizontalAlignment="Right"
                                            Content="Connect"
                                            Style="{StaticResource SecondaryButton}"
                                            Padding="10,5"
                                            FontSize="11"
                                            Visibility="{Binding IsConnected, Converter={StaticResource InvBoolToVis}}"
                                            Command="{Binding DataContext.ConnectCommand,
                                                RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"/>

                                    <Button HorizontalAlignment="Right"
                                            Content="Disconnect"
                                            Style="{StaticResource DangerButton}"
                                            Padding="10,5"
                                            FontSize="11"
                                            Visibility="{Binding IsConnected, Converter={StaticResource BoolToVis}}"
                                            Command="{Binding DataContext.DisconnectCommand,
                                                RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"/>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
