<UserControl x:Class="AvocorCommander.Views.DatabaseView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:core="clr-namespace:AvocorCommander.Core">

    <UserControl.Resources>
        <core:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <DockPanel>
        <!-- Header -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource PanelBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="20,14">
            <Grid>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="DATABASE MANAGEMENT"
                               FontSize="10" FontWeight="Bold"
                               Foreground="{DynamicResource SubtleTextBrush}"/>
                    <TextBlock Text="Edit commands, models, OUI MAC prefixes, and groups"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               Margin="0,2,0,0"/>
                </StackPanel>
                <Button HorizontalAlignment="Right"
                        Content="↺  Refresh"
                        Style="{StaticResource SecondaryButton}"
                        VerticalAlignment="Center"
                        Command="{Binding RefreshCmd}"/>
            </Grid>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource PanelBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="20,6">
            <TextBlock Text="{Binding StatusMessage}"
                       FontSize="11"
                       Foreground="{DynamicResource SecondaryTextBrush}"/>
        </Border>

        <!-- Tab row -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource PanelBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Margin="14,0">
                <Button Content="Commands"   Style="{StaticResource NavButton}" Padding="14,10"
                        Command="{Binding SwitchTabCommand}" CommandParameter="Commands"/>
                <Button Content="Models"     Style="{StaticResource NavButton}" Padding="14,10"
                        Command="{Binding SwitchTabCommand}" CommandParameter="Models"/>
                <Button Content="OUI Table"  Style="{StaticResource NavButton}" Padding="14,10"
                        Command="{Binding SwitchTabCommand}" CommandParameter="OUI"/>
                <Button Content="Groups"     Style="{StaticResource NavButton}" Padding="14,10"
                        Command="{Binding SwitchTabCommand}" CommandParameter="Groups"/>
            </StackPanel>
        </Border>

        <!-- Tab content -->
        <Grid Margin="20,14">

            <!-- ── Commands Tab ────────────────────────────────────────────── -->
            <Grid Visibility="{Binding IsCommandsTab, Converter={StaticResource BoolToVis}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="320"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource Card}" Padding="0">
                    <DataGrid ItemsSource="{Binding Commands}"
                              SelectedItem="{Binding SelectedCommand}"
                              FontFamily="Consolas" FontSize="11">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Series"   Binding="{Binding SeriesPattern}"   Width="90"/>
                            <DataGridTextColumn Header="Category" Binding="{Binding CommandCategory}" Width="110"/>
                            <DataGridTextColumn Header="Name"     Binding="{Binding CommandName}"     Width="*"/>
                            <DataGridTextColumn Header="Port"     Binding="{Binding Port}"            Width="60"/>
                            <DataGridTextColumn Header="Fmt"      Binding="{Binding CommandFormat}"   Width="45"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource Card}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="EDIT COMMAND" Style="{StaticResource SectionLabel}"/>

                            <TextBlock Text="Series" Style="{StaticResource FieldLabel}"/>
                            <ComboBox ItemsSource="{Binding AllSeries}"
                                      Text="{Binding CmdSeries}"
                                      IsEditable="True" Margin="0,0,0,10"/>

                            <TextBlock Text="Category" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding CmdCategory, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,10"/>

                            <TextBlock Text="Name" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding CmdName, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,10"/>

                            <TextBlock Text="Code" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding CmdCode, UpdateSourceTrigger=PropertyChanged}"
                                     FontFamily="Consolas" Margin="0,0,0,10"/>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="90"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Port" Style="{StaticResource FieldLabel}"/>
                                    <TextBox Text="{Binding CmdPort, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Format" Style="{StaticResource FieldLabel}"/>
                                    <ComboBox SelectedValue="{Binding CmdFormat}"
                                              SelectedValuePath="Content">
                                        <ComboBoxItem Content="HEX"/>
                                        <ComboBoxItem Content="ASCII"/>
                                    </ComboBox>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Notes" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding CmdNotes, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,14"/>

                            <Separator/>
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Button Content="Save"   Style="{StaticResource PrimaryButton}"   Command="{Binding SaveCommandCmd}"   Margin="0,0,8,0"/>
                                <Button Content="New"    Style="{StaticResource SecondaryButton}" Command="{Binding NewCommandCmd}"    Margin="0,0,8,0"/>
                                <Button Content="Delete" Style="{StaticResource DangerButton}"    Command="{Binding DeleteCommandCmd}"/>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>

            <!-- ── Models Tab ──────────────────────────────────────────────── -->
            <Grid Visibility="{Binding IsModelsTab, Converter={StaticResource BoolToVis}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="280"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource Card}" Padding="0">
                    <DataGrid ItemsSource="{Binding ModelEntries}"
                              SelectedItem="{Binding SelectedModel}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Model Number"   Binding="{Binding ModelNumber}"   Width="*"/>
                            <DataGridTextColumn Header="Series Pattern" Binding="{Binding SeriesPattern}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="EDIT MODEL" Style="{StaticResource SectionLabel}"/>
                        <TextBlock Text="Model Number" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding ModelNumber, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>
                        <TextBlock Text="Series Pattern" Style="{StaticResource FieldLabel}"/>
                        <ComboBox ItemsSource="{Binding AllSeries}" Text="{Binding ModelSeries}" IsEditable="True" Margin="0,0,0,14"/>
                        <Separator/>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button Content="Save"   Style="{StaticResource PrimaryButton}"   Command="{Binding SaveModelCmd}"   Margin="0,0,8,0"/>
                            <Button Content="New"    Style="{StaticResource SecondaryButton}" Command="{Binding NewModelCmd}"    Margin="0,0,8,0"/>
                            <Button Content="Delete" Style="{StaticResource DangerButton}"    Command="{Binding DeleteModelCmd}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ── OUI Tab ─────────────────────────────────────────────────── -->
            <Grid Visibility="{Binding IsOuiTab, Converter={StaticResource BoolToVis}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="300"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource Card}" Padding="0">
                    <DataGrid ItemsSource="{Binding OuiEntries}"
                              SelectedItem="{Binding SelectedOui}"
                              FontFamily="Consolas" FontSize="12">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="OUI Prefix"     Binding="{Binding OUIPrefix}"     Width="110"/>
                            <DataGridTextColumn Header="Series Label"   Binding="{Binding SeriesLabel}"   Width="*"/>
                            <DataGridTextColumn Header="Series Pattern" Binding="{Binding SeriesPattern}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="EDIT OUI ENTRY" Style="{StaticResource SectionLabel}"/>
                        <TextBlock Text="OUI Prefix (XX:XX:XX)" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding OuiPrefix, UpdateSourceTrigger=PropertyChanged}" FontFamily="Consolas" Margin="0,0,0,10"/>
                        <TextBlock Text="Series Label" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding OuiLabel, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>
                        <TextBlock Text="Series Pattern" Style="{StaticResource FieldLabel}"/>
                        <ComboBox ItemsSource="{Binding AllSeries}" Text="{Binding OuiSeries}" IsEditable="True" Margin="0,0,0,10"/>
                        <TextBlock Text="Notes" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding OuiNotes, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,14"/>
                        <Separator/>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button Content="Save"   Style="{StaticResource PrimaryButton}"   Command="{Binding SaveOuiCmd}"   Margin="0,0,8,0"/>
                            <Button Content="New"    Style="{StaticResource SecondaryButton}" Command="{Binding NewOuiCmd}"    Margin="0,0,8,0"/>
                            <Button Content="Delete" Style="{StaticResource DangerButton}"    Command="{Binding DeleteOuiCmd}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ── Groups Tab ──────────────────────────────────────────────── -->
            <Grid Visibility="{Binding IsGroupsTab, Converter={StaticResource BoolToVis}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="250"/>
                </Grid.ColumnDefinitions>

                <!-- Groups list -->
                <Border Grid.Column="0" Style="{StaticResource Card}" Padding="0">
                    <ListBox ItemsSource="{Binding GroupEntries}"
                             SelectedItem="{Binding SelectedGroup}"
                             ItemContainerStyle="{StaticResource TransparentListItem}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="12,9"
                                        BorderBrush="{DynamicResource DividerBrush}"
                                        BorderThickness="0,0,0,1">
                                    <StackPanel>
                                        <TextBlock Text="{Binding GroupName}"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                                        <TextBlock Text="{Binding MemberSummary}"
                                                   FontSize="10"
                                                   Foreground="{DynamicResource SubtleTextBrush}"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>

                <!-- Device membership list (handled in code-behind) -->
                <Border Grid.Column="2" Style="{StaticResource Card}" Padding="0"
                        x:Name="MembersBorder">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Padding="12,8"
                                BorderBrush="{DynamicResource DividerBrush}"
                                BorderThickness="0,0,0,1">
                            <TextBlock Text="MEMBER DEVICES — click to toggle"
                                       FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource SubtleTextBrush}"/>
                        </Border>
                        <ListBox x:Name="DeviceList"
                                 ItemsSource="{Binding AllDevices}"
                                 ItemContainerStyle="{StaticResource TransparentListItem}"
                                 MouseLeftButtonUp="DeviceList_Toggle">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="12,8"
                                            BorderBrush="{DynamicResource DividerBrush}"
                                            BorderThickness="0,0,0,1"
                                            Cursor="Hand"
                                            Tag="{Binding Id}">
                                        <Grid>
                                            <StackPanel Margin="0,0,0,0">
                                                <TextBlock Text="{Binding DeviceName}"
                                                           FontSize="12"
                                                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                                                <TextBlock Text="{Binding AddressSummary}"
                                                           FontSize="10"
                                                           Foreground="{DynamicResource SubtleTextBrush}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </Border>

                <!-- Group edit form -->
                <Border Grid.Column="4" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="EDIT GROUP" Style="{StaticResource SectionLabel}"/>
                        <TextBlock Text="Group Name" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding GroupName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>
                        <TextBlock Text="Notes" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding GroupNotes, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,14"/>
                        <Separator/>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button Content="Save"   Style="{StaticResource PrimaryButton}"   Command="{Binding SaveGroupCmd}"   Margin="0,0,8,0"/>
                            <Button Content="New"    Style="{StaticResource SecondaryButton}" Command="{Binding NewGroupCmd}"    Margin="0,0,8,0"/>
                            <Button Content="Delete" Style="{StaticResource DangerButton}"    Command="{Binding DeleteGroupCmd}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

        </Grid>
    </DockPanel>
</UserControl>
