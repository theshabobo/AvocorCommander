<UserControl x:Class="AvocorCommander.Views.MacroView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:core="clr-namespace:AvocorCommander.Core">

    <UserControl.Resources>
        <core:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <core:BoolToVisibilityConverter x:Key="InvBoolToVis" Invert="True"/>
    </UserControl.Resources>

    <DockPanel>
        <!-- Header -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource PanelBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1" Padding="20,14">
            <Grid>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="MACROS" FontSize="10" FontWeight="Bold"
                               Foreground="{DynamicResource SubtleTextBrush}"/>
                    <TextBlock Text="Multi-step command sequences"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,2,0,0"/>
                </StackPanel>
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="&#8635;  Refresh" Style="{StaticResource SecondaryButton}"
                            Command="{Binding RefreshCommand}" Margin="0,0,8,0"/>
                    <Button Content="&#65291;  Add Macro" Style="{StaticResource PrimaryButton}"
                            Command="{Binding AddMacroCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource PanelBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0" Padding="20,6">
            <TextBlock Text="{Binding StatusMessage}" FontSize="11"
                       Foreground="{DynamicResource SecondaryTextBrush}"/>
        </Border>

        <!-- Run bar -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource InfoBarBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0" Padding="20,10">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Run on:" FontSize="11"
                               Foreground="{DynamicResource LabelBrush}"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <RadioButton Content="Device" IsChecked="{Binding RunOnDevice}"
                                 Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <ComboBox ItemsSource="{Binding AllDevices}" SelectedItem="{Binding RunDevice}"
                              DisplayMemberPath="DeviceName" Width="180"
                              Visibility="{Binding RunOnDevice, Converter={StaticResource BoolToVis}}"
                              Margin="0,0,20,0"/>
                    <RadioButton Content="Group" IsChecked="{Binding RunOnGroup}"
                                 Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <ComboBox ItemsSource="{Binding AllGroups}" SelectedItem="{Binding RunGroup}"
                              DisplayMemberPath="GroupName" Width="160"
                              Visibility="{Binding RunOnGroup, Converter={StaticResource BoolToVis}}"
                              Margin="0,0,20,0"/>
                </StackPanel>
                <Button HorizontalAlignment="Right" Content="&#9654;  Run Macro"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding RunMacroCommand}"/>
            </Grid>
        </Border>

        <!-- Body: macro list | steps -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" MinWidth="180"/>
                <ColumnDefinition Width="1"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Macro list -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Padding="14,12">
                <StackPanel>
                    <TextBlock Text="No macros yet. Click + Add Macro to create one."
                               Foreground="{DynamicResource PlaceholderBrush}"
                               FontSize="13" TextAlignment="Center" TextWrapping="Wrap" MaxWidth="220"
                               HorizontalAlignment="Center" Margin="0,50,0,0"
                               Visibility="{Binding Macros.Count, Converter={StaticResource InvBoolToVis}}"/>
                    <ItemsControl ItemsSource="{Binding Macros}" x:Name="MacroList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,8" Style="{StaticResource Card}"
                                        Cursor="Hand" MouseLeftButtonUp="MacroCard_Click">
                                    <Grid>
                                        <StackPanel Margin="0,0,64,0">
                                            <TextBlock Text="{Binding MacroName}"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"/>
                                            <TextBlock Text="{Binding StepSummary}" FontSize="11"
                                                       Foreground="{DynamicResource SubtleTextBrush}" Margin="0,3,0,0"/>
                                            <TextBlock Text="{Binding Notes}" FontSize="11"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                       TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                            <Button Content="&#9998;" Style="{StaticResource IconButton}" ToolTip="Edit macro"
                                                    Command="{Binding DataContext.EditMacroCommand,
                                                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"/>
                                            <Button Content="&#10005;" Style="{StaticResource IconButton}" ToolTip="Delete"
                                                    Foreground="{DynamicResource ErrorBrush}"
                                                    Command="{Binding DataContext.DeleteMacroCommand,
                                                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>

            <!-- Divider -->
            <Border Grid.Column="1" Background="{DynamicResource BorderBrush}"/>

            <!-- Steps panel -->
            <DockPanel Grid.Column="2">
                <Border DockPanel.Dock="Top"
                        Background="{DynamicResource PanelBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,0,0,1" Padding="18,10">
                    <Grid>
                        <TextBlock FontSize="11" FontWeight="Bold" VerticalAlignment="Center"
                                   Foreground="{DynamicResource SubtleTextBrush}">
                            <Run Text="STEPS  "/>
                            <Run Text="{Binding SelectedMacro.MacroName, FallbackValue='— select a macro —'}"
                                 Foreground="{DynamicResource PrimaryTextBrush}"/>
                        </TextBlock>
                        <Button HorizontalAlignment="Right"
                                Content="&#9998;  Edit Steps"
                                Style="{StaticResource SecondaryButton}"
                                Visibility="{Binding HasSelection, Converter={StaticResource BoolToVis}}"
                                Command="{Binding EditMacroCommand}"
                                CommandParameter="{Binding SelectedMacro}"/>
                    </Grid>
                </Border>

                <TextBlock DockPanel.Dock="Top"
                           Text="Click a macro on the left to view its steps."
                           Foreground="{DynamicResource PlaceholderBrush}" FontSize="13"
                           TextAlignment="Center" HorizontalAlignment="Center" Margin="0,60,0,0"
                           Visibility="{Binding HasSelection, Converter={StaticResource InvBoolToVis}}"/>

                <DataGrid ItemsSource="{Binding Steps}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          FontFamily="Consolas" FontSize="12" Margin="0"
                          Visibility="{Binding HasSelection, Converter={StaticResource BoolToVis}}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="#"       Binding="{Binding StepOrder}"    Width="40"/>
                        <DataGridTextColumn Header="Command" Binding="{Binding CommandName}"  Width="*"/>
                        <DataGridTextColumn Header="Series"  Binding="{Binding SeriesPattern}" Width="110"/>
                        <DataGridTextColumn Header="Delay"   Binding="{Binding DelayDisplay}" Width="90"/>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Grid>
    </DockPanel>
</UserControl>
