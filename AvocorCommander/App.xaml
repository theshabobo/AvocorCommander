<Application x:Class="AvocorCommander.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:core="clr-namespace:AvocorCommander.Core"
             StartupUri="MainWindow.xaml"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/Dark.xaml"/>
                <ResourceDictionary Source="Themes/Controls.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <!-- App-wide converters so every window can use them -->
            <core:BoolToVisibilityConverter x:Key="BoolToVis"/>
            <core:EqualsToBoolConverter     x:Key="EqBool"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
